{{/* chezmoi config template — prompts run once on `chezmoi init`. */}}
{{- $name := promptStringOnce . "name" "Full name" "Dave Thai" -}}
{{- $email := promptStringOnce . "email" "Personal git email" "davethai93@gmail.com" -}}
{{- $signingKey := promptStringOnce . "signingKey" "SSH signing public key (full 'ssh-ed25519 AAAA...' line; blank to disable commit signing)" "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAlrzGbaqXnERKhTBIaoxLXvuzAI+qt9rgKJxmau9uBr" -}}
{{- $workEmail := promptStringOnce . "workEmail" "Work git email (blank to skip)" "" -}}
{{- $workDir := promptStringOnce . "workDir" "Work git dir for includeIf, e.g. ~/Documents/dev/acme/ (blank to skip)" "" -}}
{{- $profile := promptStringOnce . "profile" "Profile: full (everything) | minimal (shell + core CLI, no k8s/containers/GUI)" "full" -}}

{{ if stat (joinPath .chezmoi.homeDir ".dotfiles" ".git") -}}
# This machine edits the repo directly at ~/.dotfiles, so point chezmoi there.
# Fresh clones (`chezmoi init <user>`) have no ~/.dotfiles and use the default.
sourceDir = {{ (joinPath .chezmoi.homeDir ".dotfiles") | quote }}
{{ end -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    signingKey = {{ $signingKey | quote }}
    workEmail = {{ $workEmail | quote }}
    workDir = {{ $workDir | quote }}
    profile = {{ $profile | quote }}
