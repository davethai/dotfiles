{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# Install macOS GUI apps + native CLIs from the Brewfile.
# Re-runs whenever the Brewfile changes (hash below).
set -euo pipefail

# Brewfile hash: {{ include (joinPath .chezmoi.sourceDir ".." "Brewfile") | sha256sum }}

[[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"

# Homebrew 6 refuses to load formulae from third-party taps until they're
# trusted. Tap + trust the ones our Brewfile uses before bundling.
for t in slp/krunkit dbt-labs/dbt-cli hashicorp/tap argoproj/tap infisical/get-cli; do
  brew tap "$t" 2>/dev/null || true
  brew trust "$t" 2>/dev/null || true
done

echo "==> brew bundle"
brew bundle --file="{{ joinPath .chezmoi.sourceDir ".." "Brewfile" }}"
{{- end }}
