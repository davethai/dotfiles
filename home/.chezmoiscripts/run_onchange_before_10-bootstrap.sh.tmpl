#!/usr/bin/env bash
# Bootstrap prerequisites: package manager + mise + zsh as login shell.
# run_onchange: re-runs whenever this script changes (idempotent). Heavy bits
# (containers, PHP build deps) are gated to profile = "full".
set -euo pipefail

echo "==> Bootstrapping ({{ .chezmoi.os }}/{{ .chezmoi.arch }})"

{{ if eq .chezmoi.os "linux" -}}
# ── Linux: apt (Debian/Ubuntu) or dnf (RHEL/Fedora). System packages need root.
# Probe sudo first: root or passwordless → use directly; real sudoer → prompt
# once; locked-down box (not in sudoers) → skip system packages silently and let
# mise install the rest to ~/.local. Avoids hanging/erroring on no-privilege boxes. ──
SUDO=""
if [ "$(id -u)" -eq 0 ]; then
  :                                                    # already root
elif command -v sudo &>/dev/null; then
  if sudo -n true 2>/dev/null; then
    SUDO="sudo"                                        # passwordless sudo
  elif sudo -nv 2>&1 | grep -q 'password is required'; then
    SUDO="sudo"                                        # in sudoers (prompts once)
  fi
fi

if [ -z "$SUDO" ] && [ "$(id -u)" -ne 0 ]; then
  echo "==> no sudo rights — skipping system packages; mise installs the rest to ~/.local"
elif command -v apt-get &>/dev/null; then
  echo "==> apt: base system packages"
  $SUDO apt-get update -y && $SUDO apt-get install -y --no-install-recommends \
    build-essential procps curl file git unzip ca-certificates zsh chafa \
    || echo "   (apt failed — continuing)"
{{ if eq .profile "full" }}
  $SUDO apt-get install -y --no-install-recommends podman podman-compose uidmap slirp4netns || true
  $SUDO apt-get install -y docker.io docker-compose-v2 || true
  $SUDO usermod -aG docker "$USER" 2>/dev/null || true
  $SUDO systemctl enable --now docker 2>/dev/null || true
  # PHP build deps — so `mise use php@x.y` compiles with the usual extensions.
  $SUDO apt-get install -y --no-install-recommends \
    autoconf bison re2c pkg-config plocate libxml2-dev libssl-dev libcurl4-openssl-dev \
    libonig-dev libzip-dev libsqlite3-dev libpq-dev libreadline-dev libbz2-dev \
    zlib1g-dev libgd-dev libpng-dev libjpeg-dev libfreetype6-dev libicu-dev libxslt1-dev libgmp-dev || true
{{ end }}
elif command -v dnf &>/dev/null; then
  echo "==> dnf: base system packages (RHEL/Fedora)"
  $SUDO dnf install -y zsh git curl tar gzip which findutils procps-ng \
    || echo "   (dnf failed — continuing)"
{{ if eq .profile "full" }}
  $SUDO dnf install -y podman gcc gcc-c++ make || true
{{ end }}
fi
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
# ── macOS: Xcode CLT + Homebrew ──
if ! xcode-select -p &>/dev/null; then
  echo "==> Installing Xcode Command Line Tools (follow the GUI prompt, then re-run)"
  xcode-select --install || true
fi
if ! command -v brew &>/dev/null; then
  echo "==> Installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
[[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"
{{- end }}

# ── mise (both platforms) ──
if ! command -v mise &>/dev/null && [[ ! -x "$HOME/.local/bin/mise" ]]; then
  echo "==> Installing mise"
  curl -fsSL https://mise.run | sh
fi
export PATH="$HOME/.local/bin:$PATH"

# ── default shell → zsh ──
if command -v zsh &>/dev/null && [[ "${SHELL:-}" != *zsh ]]; then
  echo "==> Setting default shell to zsh"
  chsh -s "$(command -v zsh)" || echo "   (chsh failed; change your shell manually)"
fi
