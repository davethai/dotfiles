#!/usr/bin/env bash
# Bootstrap prerequisites: package manager + mise + zsh as login shell.
# Runs ONCE per machine (run_once), before any dotfiles are written.
set -euo pipefail

echo "==> Bootstrapping ({{ .chezmoi.os }}/{{ .chezmoi.arch }})"

{{ if eq .chezmoi.os "linux" -}}
# ── Linux / WSL: apt provides the base system; mise does the rest ──
if command -v apt-get &>/dev/null; then
  echo "==> apt: base system packages"
  sudo apt-get update -y
  sudo apt-get install -y --no-install-recommends \
    build-essential procps curl file git unzip ca-certificates zsh chafa \
    podman podman-compose uidmap slirp4netns

  # Docker — for Docker-first repos. Ubuntu's own packages (no external apt repo
  # to break on new releases). Podman stays installed for personal/rootless use.
  sudo apt-get install -y docker.io docker-compose-v2
  sudo usermod -aG docker "$USER" 2>/dev/null || true
  sudo systemctl enable --now docker 2>/dev/null || true

  # PHP build deps — so `mise use php@x.y` compiles with the usual extensions
  # (dom, mbstring, pdo_pgsql, intl, gd, zip, ...). Version stays per-project.
  sudo apt-get install -y --no-install-recommends \
    autoconf bison re2c pkg-config plocate libxml2-dev libssl-dev libcurl4-openssl-dev \
    libonig-dev libzip-dev libsqlite3-dev libpq-dev libreadline-dev libbz2-dev \
    zlib1g-dev libgd-dev libpng-dev libjpeg-dev libfreetype6-dev libicu-dev libxslt1-dev libgmp-dev
fi
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
# ── macOS: Xcode CLT + Homebrew ──
if ! xcode-select -p &>/dev/null; then
  echo "==> Installing Xcode Command Line Tools (follow the GUI prompt, then re-run)"
  xcode-select --install || true
fi
if ! command -v brew &>/dev/null; then
  echo "==> Installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
[[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"
{{- end }}

# ── mise (both platforms) ──
if ! command -v mise &>/dev/null && [[ ! -x "$HOME/.local/bin/mise" ]]; then
  echo "==> Installing mise"
  curl -fsSL https://mise.run | sh
fi
export PATH="$HOME/.local/bin:$PATH"

# ── default shell → zsh ──
if command -v zsh &>/dev/null && [[ "${SHELL:-}" != *zsh ]]; then
  echo "==> Setting default shell to zsh"
  chsh -s "$(command -v zsh)" || echo "   (chsh failed; change your shell manually)"
fi
